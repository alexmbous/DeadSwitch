{
  "name": "@deadswitch/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:release-worker": "node dist/workers/release.worker.js",
    "start:checkins-worker": "node dist/workers/checkins.worker.js",
    "start:escalation-worker": "node dist/workers/escalation.worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test:integration:up": "docker compose -f docker-compose.test.yml up -d",
    "test:integration:down": "docker compose -f docker-compose.test.yml down -v",
    "test:integration": "jest --config jest-integration.config.ts --runInBand"
  },
  "dependencies": {
    "@deadswitch/shared": "workspace:*",
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/throttler": "^6.0.0",
    "@prisma/client": "^5.14.0",
    "argon2": "^0.40.1",
    "bullmq": "^5.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "twilio": "^5.0.0",
    "@sendgrid/mail": "^8.1.3",
    "@aws-sdk/client-s3": "^3.600.0",
    "pino": "^9.0.0",
    "prom-client": "^15.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.12.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.0",
    "jest": "^29.7.0",
    "pg": "^8.11.0",
    "prisma": "^5.14.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
