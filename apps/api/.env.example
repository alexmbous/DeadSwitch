NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://deaddrop:deaddrop@localhost:5432/deaddrop?schema=public
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# KMS: for local dev we use a file-backed mock; production must set AWS_KMS_KEY_ID
KMS_MODE=mock
KMS_MOCK_MASTER_KEY_BASE64=
AWS_KMS_KEY_ID=
AWS_REGION=us-east-1

SENDGRID_API_KEY=
SENDGRID_FROM=no-reply@deadswitch.local

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VOICE_CALLBACK_URL=

# Governance
ACCOUNT_COOLDOWN_SECONDS=259200
MAX_SCENARIOS_PER_USER=5
MAX_BUNDLES_PER_SCENARIO=10
MAX_RECIPIENTS_PER_BUNDLE=25
MIN_GRACE_PERIOD_SECONDS=21600
